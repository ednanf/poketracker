{
    "name": "backend",
    "version": "1.0.0",
    "description": "",
    "main": "index.js",
    "scripts": {
        "build": "tsc",
        "check": "tsc --noEmit",
        "check:watch": "tsc --noEmit --watch",
        "clean": "rimraf dist .tsbuildinfo .turbo node_modules/.cache",
        "dev": "node --env-file=.env --import tsx --watch src/server.ts",
        "lint": "eslint \"src/**/*.{ts,tsx}\"",
        "lint:fix": "yarn lint --fix",
        "rebuild": "yarn clean && yarn install && yarn build",
        "start": "node --env-file=.env dist/server.js",
        "test": "vitest",
        "test:ui": "vitest --ui",
        "test:run": "vitest run",
        "update": "yarn upgrade-interactive --latest"
    },
    "keywords": [
        "backend",
        "nodejs",
        "jwt"
    ],
    "author": "Ednan Rogério Frizzera Filho",
    "license": "UNLICENSED",
    "private": "true",
    "type": "module",
    "dependencies": {
        "@poketracker/shared": "*",
        "bcryptjs": "^3.0.3",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.6",
        "express": "^5.2.1",
        "express-rate-limit": "^8.3.2",
        "express-xss-sanitizer": "^2.0.2",
        "helmet": "^8.1.0",
        "http-status-codes": "^2.3.0",
        "jsonwebtoken": "^9.0.3",
        "mongoose": "^9.4.1",
        "morgan": "^1.10.1",
        "ms": "^2.1.3",
        "validator": "^13.15.35",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/bcryptjs": "^3.0.0",
        "@types/cookie-parser": "^1.4.10",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/express-xss-sanitizer": "^2.0.0",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/morgan": "^1.9.10",
        "@types/node": "^25.6.0",
        "@types/supertest": "^7.2.0",
        "@types/validator": "^13.15.10",
        "@vitest/coverage-v8": "^4.1.4",
        "rimraf": "^6.1.3",
        "supertest": "^7.2.2",
        "tsx": "^4.21.0",
        "vitest": "^4.1.4"
    }
}
